{
  "name": "arc-workflows",
  "version": "0.0.0",
  "description": "Interactive CLI wizard for creating GitHub Actions workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "arc-workflows": "./dist/bin/arc-workflows.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run"
  },
  "dependencies": {
    "@arc-workflows/core": "workspace:*",
    "@inkjs/ui": "^2.0.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "xstate": "^5.18.0",
    "@xstate/react": "^4.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "ink-testing-library": "^4.0.0"
  },
  "license": "ISC"
}
