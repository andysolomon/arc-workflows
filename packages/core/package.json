{
  "name": "@arc-workflows/core",
  "version": "0.0.0",
  "description": "Schema, validation, YAML generation, and built-in templates for GitHub Actions workflows",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "github-actions",
    "workflow",
    "yaml",
    "ci",
    "cd",
    "schema",
    "validation",
    "typescript"
  ],
  "homepage": "https://github.com/andysolomon/arc-workflows#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/andysolomon/arc-workflows.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/andysolomon/arc-workflows/issues"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run"
  },
  "license": "ISC",
  "dependencies": {
    "cron-parser": "^4.9.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "expect-type": "^1.3.0"
  }
}
